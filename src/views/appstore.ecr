<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Jomashop App</title>

    <!--
      In-app download trigger.
      Loaded inside the Jomashop app webview to open the native store
      for rating, updating, or sharing with a friend.
    -->
    <script>
      (function () {
        var ua = navigator.userAgent || navigator.vendor || window.opera;

        if (/iPad|iPhone|iPod/.test(ua) && !window.MSStream) {
          // itms-apps:// opens App Store natively from the app's webview
          window.location.replace("itms-apps://itunes.apple.com/app/id6444218472");
        } else if (/android/i.test(ua)) {
          // market:// opens Play Store natively from the app's webview
          window.location.replace("market://details?id=com.jomashop.app");
        }
      })();
    </script>

    <style>
      @font-face {
        font-family: 'Inter';
        font-weight: 400 700;
        font-display: swap;
        src: url('https://www.jomashop.com/dist/file/Inter-Regular-subset-latin.c12fef52fecfde9da501.woff2') format('woff2');
      }
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #fff;
        color: #1a1a1a;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
      }
      .container {
        text-align: center;
        padding: 2rem 1.5rem;
        max-width: 380px;
      }
      .logo { margin-bottom: 2rem; }
      .logo img { height: 22px; width: auto; }
      p {
        font-size: 0.85rem;
        color: #777;
        line-height: 1.4;
        margin-bottom: 1.75rem;
      }
      .badges {
        display: flex;
        justify-content: center;
        gap: 0.75rem;
      }
      .badges a {
        display: block;
        transition: opacity 0.15s ease;
      }
      .badges a:hover { opacity: 0.75; }
      .badges img {
        height: 44px;
        width: auto;
        display: block;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="logo">
        <img src="https://www.jomashop.com/assets/joma/jomashop_logo.png" alt="Jomashop" height="22" width="190" />
      </div>

      <p>Opening your store…</p>

      <div class="badges">
        <a href="https://apps.apple.com/us/app/jomashop-designer-shopping/id6444218472">
          <img src="https://www.jomashop.com/media/cms/app/download_ios.png" alt="Download on the App Store" />
        </a>
        <a href="https://play.google.com/store/apps/details?id=com.jomashop.app">
          <img src="https://www.jomashop.com/media/cms/app/download_android.png" alt="Get it on Google Play" />
        </a>
      </div>
    </div>
  </body>
</html>
