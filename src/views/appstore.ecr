<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Get the Jomashop App</title>
    <meta name="description" content="Download the Jomashop app for iOS or Android." />

    <!-- Immediate JS redirect (fires before page renders) -->
    <script>
      (function () {
        var ua = navigator.userAgent || navigator.vendor || window.opera;
        var IOS_URL     = "https://apps.apple.com/us/app/jomashop-designer-shopping/id6444218472";
        var ANDROID_URL = "https://play.google.com/store/apps/details?id=com.jomashop.app";
        var FALLBACK    = "https://www.jomashop.com/flash-sale-offers.html";

      })();
    </script>

    <style>
      @font-face {
        font-family: 'Inter';
        font-weight: 400 700;
        font-display: swap;
        src: url('https://www.jomashop.com/dist/file/Inter-Regular-subset-latin.c12fef52fecfde9da501.woff2') format('woff2');
      }

      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #fff;
        color: #1a1a1a;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
      }

      .container {
        text-align: center;
        padding: 2rem 1.5rem;
        max-width: 380px;
      }

      .logo {
        margin-bottom: 2rem;
      }
      .logo img {
        height: 22px;
        width: auto;
      }

      h1 {
        font-size: 1.15rem;
        font-weight: 600;
        color: #1a1a1a;
        margin-bottom: 0.35rem;
        letter-spacing: -0.01em;
      }

      .subtitle {
        font-size: 0.85rem;
        color: #777;
        margin-bottom: 1.75rem;
        line-height: 1.4;
      }

      .badges {
        display: flex;
        justify-content: center;
        gap: 0.75rem;
      }

      .badges a {
        display: block;
        transition: opacity 0.15s ease;
      }
      .badges a:hover {
        opacity: 0.75;
      }

      .badges img {
        height: 44px;
        width: auto;
        display: block;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="logo">
        <img src="https://www.jomashop.com/assets/joma/jomashop_logo.png" alt="Jomashop" height="22" width="190" />
      </div>

      <h1>Never pay retail.</h1>
      <p class="subtitle">Our app makes it easy.</p>

      <div class="badges">
        <a id="btn-ios" href="https://apps.apple.com/us/app/jomashop-designer-shopping/id6444218472">
          <img src="https://www.jomashop.com/media/cms/app/download_ios.png" alt="Download on the App Store" />
        </a>
        <a id="btn-android" href="https://play.google.com/store/apps/details?id=com.jomashop.app">
          <img src="https://www.jomashop.com/media/cms/app/download_android.png" alt="Get it on Google Play" />
        </a>
      </div>
    </div>
  </body>
</html>