<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Update Jomashop</title>
    <meta name="description" content="Update the Jomashop app to the latest version." />

    <!--
      Apple Smart App Banner — rendered by iOS natively, NOT by the webview.
      Tapping "VIEW" always opens the App Store, even from inside WKWebView.
    -->
    <meta name="apple-itunes-app" content="app-id=6444218472" />

    <script>
      (function () {
        var ua = navigator.userAgent || navigator.vendor || window.opera;

        // Android: intent:// breaks out of WebView reliably
        if (/android/i.test(ua)) {
          window.location.replace(
            "intent://details?id=com.jomashop.app#Intent;scheme=market;package=com.android.vending;S.browser_fallback_url=https%3A%2F%2Fplay.google.com%2Fstore%2Fapps%2Fdetails%3Fid%3Dcom.jomashop.app;end"
          );
        }
        // iOS: do NOT auto-redirect — the Smart App Banner handles it.
        // The page renders with a visible "Update" button as fallback.
      })();
    </script>

    <style>
      @font-face {
        font-family: 'Inter';
        font-weight: 400 700;
        font-display: swap;
        src: url('https://www.jomashop.com/dist/file/Inter-Regular-subset-latin.c12fef52fecfde9da501.woff2') format('woff2');
      }

      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #fff;
        color: #1a1a1a;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
      }

      .container {
        text-align: center;
        padding: 2rem 1.5rem;
        max-width: 380px;
      }

      .logo {
        margin-bottom: 2rem;
      }
      .logo img {
        height: 22px;
        width: auto;
      }

      h1 {
        font-size: 1.15rem;
        font-weight: 600;
        color: #1a1a1a;
        margin-bottom: 0.35rem;
        letter-spacing: -0.01em;
      }

      .subtitle {
        font-size: 0.85rem;
        color: #777;
        margin-bottom: 1.75rem;
        line-height: 1.4;
      }

      .update-btn {
        display: inline-block;
        background: #1a1a1a;
        color: #fff;
        font-family: inherit;
        font-size: 0.9rem;
        font-weight: 600;
        padding: 0.75rem 2.5rem;
        border: none;
        border-radius: 6px;
        text-decoration: none;
        cursor: pointer;
        transition: opacity 0.15s ease;
        margin-bottom: 1rem;
      }
      .update-btn:hover {
        opacity: 0.8;
      }

      .hint {
        font-size: 0.72rem;
        color: #aaa;
        line-height: 1.4;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="logo">
        <img src="https://www.jomashop.com/assets/joma/jomashop_logo.png" alt="Jomashop" height="22" width="190" />
      </div>

      <h1>A new version is available.</h1>
      <p class="subtitle">Update to get the latest features.</p>

      <a
        class="update-btn"
        id="btn-update"
        href="https://apps.apple.com/us/app/jomashop-designer-shopping/id6444218472"
      >Update Now</a>

      <p class="hint" id="hint-ios">Tap the banner above to open the App Store.</p>
    </div>

    <script>
      // Android: hide the iOS hint, update the button href
      (function () {
        var ua = navigator.userAgent || navigator.vendor || window.opera;
        if (/android/i.test(ua)) {
          document.getElementById('hint-ios').style.display = 'none';
          document.getElementById('btn-update').href =
            'https://play.google.com/store/apps/details?id=com.jomashop.app';
        } else if (!(/iPad|iPhone|iPod/.test(ua))) {
          // Desktop — hide the hint
          document.getElementById('hint-ios').style.display = 'none';
        }
      })();
    </script>
  </body>
</html>
